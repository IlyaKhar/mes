generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum Department {
  IT
  HR
  PROCUREMENT
  OPERATIONS
}

enum MessageKind {
  TEXT
  VOICE
  FILE
  SYSTEM
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING
  RESOLVED
  CLOSED
}

enum FileKind {
  PDF
  DOC
  IMAGE
  OTHER
}

enum EventMode {
  OFFICE
  REMOTE
  TWO_TWO
}

enum ShiftPattern {
  FIVE_TWO
  TWO_TWO
}

enum WikiPageStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ActionLogType {
  LOGIN
  CREATE
  UPDATE
  DELETE
  BAN
  ROLE_CHANGE
}

model User {
  id              String       @id @default(cuid())
  name            String
  email           String       @unique
  passwordHash    String
  avatarUrl       String?
  role            Role         @default(USER)
  department      Department   @default(OPERATIONS)
  isBanned        Boolean      @default(false)
  shiftPattern    ShiftPattern @default(FIVE_TWO)
  shiftStartedAt  DateTime?
  workdayStartsAt String       @default("09:00")
  workdayEndsAt   String       @default("18:00")
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  messages          Message[]
  chatsCreated      Chat[]        @relation("ChatCreator")
  chatParticipants  ChatParticipant[]
  assignedTasks     Task[]        @relation("TaskAssignee")
  createdTasks      Task[]        @relation("TaskCreator")
  createdTickets    Ticket[]      @relation("TicketCreator")
  assignedTickets   Ticket[]      @relation("TicketSupportAgent")
  ownedFiles        File[]
  eventsCreated     Event[]       @relation("EventCreator")
  eventParticipants EventParticipant[]
  authoredWikiPages WikiPage[]    @relation("WikiPageAuthor")
  wikiReads         WikiPageRead[]
  wikiHistories     WikiHistory[]
  fileVersions      FileVersion[]
  timeLogs          TimeLog[]
  actionLogs        ActionLog[]   @relation("ActionActor")

  @@index([department])
  @@index([role])
}

model Chat {
  id          String   @id @default(cuid())
  title       String
  description String?
  isPrivate   Boolean  @default(false)
  aiSummary   String?
  creatorId   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  creator  User?     @relation("ChatCreator", fields: [creatorId], references: [id], onDelete: SetNull)
  messages Message[]
  participants ChatParticipant[]
}

model ChatParticipant {
  id        String   @id @default(cuid())
  chatId    String
  userId    String
  joinedAt  DateTime @default(now())

  chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([chatId, userId])
  @@index([userId])
}

model Message {
  id         String      @id @default(cuid())
  body       String
  transcript String?
  kind       MessageKind @default(TEXT)
  userId     String
  chatId     String
  parentId   String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  user    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  chat    Chat      @relation(fields: [chatId], references: [id], onDelete: Cascade)
  parent  Message?  @relation("MessageThread", fields: [parentId], references: [id], onDelete: Cascade)
  replies Message[] @relation("MessageThread")

  @@index([chatId, createdAt])
  @@index([parentId])
  @@index([userId])
}

model Task {
  id          String     @id @default(cuid())
  title       String
  description String?
  status      TaskStatus @default(TODO)
  priority    Priority   @default(MEDIUM)
  dueAt       DateTime?
  assigneeId  String?
  creatorId   String
  ticketId    String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  assignee User?     @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  creator  User      @relation("TaskCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  ticket   Ticket?   @relation(fields: [ticketId], references: [id], onDelete: SetNull)
  timeLogs TimeLog[]

  @@index([assigneeId, status])
  @@index([creatorId])
  @@index([ticketId])
}

model Ticket {
  id             String       @id @default(cuid())
  number         Int          @unique @default(autoincrement())
  title          String
  description    String
  status         TicketStatus @default(OPEN)
  priority       Priority     @default(MEDIUM)
  department     Department
  slaDueAt       DateTime
  isEscalated    Boolean      @default(false)
  creatorId      String
  supportAgentId String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  creator      User   @relation("TicketCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  supportAgent User?  @relation("TicketSupportAgent", fields: [supportAgentId], references: [id], onDelete: SetNull)
  tasks        Task[]

  @@index([creatorId])
  @@index([supportAgentId])
  @@index([department, status])
  @@index([status, slaDueAt])
}

model File {
  id         String   @id @default(cuid())
  name       String
  kind       FileKind @default(OTHER)
  mimeType   String
  size       Int
  url        String
  previewUrl String?
  shareUrl   String?
  ownerId    String
  parentId   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  owner    User          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  parent   File?         @relation("FileTree", fields: [parentId], references: [id], onDelete: Cascade)
  children File[]        @relation("FileTree")
  versions FileVersion[]

  @@index([ownerId])
  @@index([parentId])
}

model FileVersion {
  id        String   @id @default(cuid())
  fileId    String
  authorId  String
  note      String
  version   Int
  createdAt DateTime @default(now())

  file   File @relation(fields: [fileId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@unique([fileId, version])
  @@index([authorId])
}

model Event {
  id          String    @id @default(cuid())
  title       String
  description String?
  startsAt    DateTime
  endsAt      DateTime
  mode        EventMode @default(OFFICE)
  creatorId   String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  creator      User               @relation("EventCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  participants EventParticipant[]

  @@index([creatorId])
  @@index([startsAt, endsAt])
}

model EventParticipant {
  id      String @id @default(cuid())
  eventId String
  userId  String

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([userId])
}

model WikiPage {
  id        String         @id @default(cuid())
  title     String
  slug      String         @unique
  content   String
  status    WikiPageStatus @default(DRAFT)
  authorId  String
  parentId  String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  author    User          @relation("WikiPageAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  parent    WikiPage?     @relation("WikiTree", fields: [parentId], references: [id], onDelete: Cascade)
  children  WikiPage[]    @relation("WikiTree")
  reads     WikiPageRead[]
  histories WikiHistory[]

  @@index([authorId])
  @@index([parentId])
}

model WikiHistory {
  id        String   @id @default(cuid())
  pageId    String
  authorId  String
  diff      Json
  createdAt DateTime @default(now())

  page   WikiPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  author User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([pageId, createdAt])
  @@index([authorId])
}

model WikiPageRead {
  id     String   @id @default(cuid())
  pageId String
  userId String
  readAt DateTime @default(now())

  page WikiPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([pageId, userId])
  @@index([userId])
}

model TimeLog {
  id              String   @id @default(cuid())
  taskId          String
  userId          String
  startedAt       DateTime
  stoppedAt       DateTime
  durationSeconds Int
  createdAt       DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([userId, startedAt])
}

model ActionLog {
  id        String        @id @default(cuid())
  actorId   String?
  type      ActionLogType
  entity    String
  entityId  String?
  metadata  Json?
  createdAt DateTime      @default(now())

  actor User? @relation("ActionActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([type])
  @@index([createdAt])
}
